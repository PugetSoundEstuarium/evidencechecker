<!DOCTYPE html>
<html>
  <head>
    <base target="_top">
    <?!= include('Styles'); ?>
  </head>
  <body>
    <script>
      window.APP_DATA = <?!= appData ?>;
    </script>

    <div class="shell">
      <div class="card">
        <div class="eyebrow">Night at the Estuary</div>
        <h1 id="appTitle"></h1>
        <p class="sub" id="appSubtitle"></p>

        <div id="statusBar" class="status-bar"></div>

        <section id="lockedView" class="view hidden">
          <h2>The Estuary Investigation is not yet open.</h2>
          <p>Your discovery has been sealed.</p>
          <p>Return on <strong id="launchDateText"></strong> to reveal what is inside.</p>
          <p class="muted">Keep your bottle safe.</p>
        </section>

        <section id="revealView" class="view hidden">
          <h2>Enter Your Code</h2>
          <p class="muted">Scan your QR code or enter the printed code below.</p>
          <div class="field">
            <label for="codeInput">Bottle code</label>
            <input id="codeInput" type="text" placeholder="ABCD-EFGH-JKLM">
          </div>
          <button id="revealBtn" class="btn">Reveal</button>
          <p id="revealError" class="error hidden"></p>
        </section>

        <section id="resultView" class="view hidden">
          <h2 id="resultTitle"></h2>
          <p id="resultMain"></p>
          <p id="resultDetail" class="muted"></p>
          <div class="progress-box">
            <div class="progress-copy" id="progressCopy"></div>
            <div class="progress-track"><div id="progressBar" class="progress-bar"></div></div>
          </div>

          <form id="registerForm">
            <input type="hidden" id="hiddenCode">
            <div class="field">
              <label for="nameInput">Name</label>
              <input id="nameInput" type="text" required>
            </div>
            <div class="field">
              <label for="emailInput">Email</label>
              <input id="emailInput" type="email" required>
            </div>
            <div class="field">
              <label for="visibilityInput">How would you like to participate?</label>
              <select id="visibilityInput"></select>
            </div>
            <label class="check"><input id="connectByEmail" type="checkbox"> Allow the Estuarium to connect me with other participants by email</label>
            <label class="check"><input id="shareEmail" type="checkbox"> Allow my email to be shared with other participants</label>
            <div class="field">
              <label for="noteInput">Note or message (optional)</label>
              <textarea id="noteInput" rows="4"></textarea>
            </div>
            <button type="submit" class="btn">Complete Registration</button>
            <p id="registerError" class="error hidden"></p>
          </form>
        </section>

        <section id="confirmationView" class="view hidden">
          <h2 id="confirmTitle"></h2>
          <p id="confirmMain"></p>
          <p id="confirmDetail" class="muted"></p>
          <div class="progress-box">
            <div class="progress-copy" id="confirmProgressCopy"></div>
            <div class="progress-track"><div id="confirmProgressBar" class="progress-bar"></div></div>
          </div>
        </section>
      </div>
    </div>

    <?!= include('ClientJS'); ?>
  </body>
</html>
